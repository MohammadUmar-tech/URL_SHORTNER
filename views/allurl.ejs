<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SHRTNR — All URLs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0a0f;
      --surface: #111118;
      --surface2: #16161f;
      --border: #1e1e2e;
      --accent: #00e5ff;
      --accent2: #ff3cac;
      --text: #e8e8f0;
      --muted: #5a5a7a;
      --row-hover: #13131c;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Syne', sans-serif;
      min-height: 100vh;
      position: relative;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
      background-size: 48px 48px;
      animation: gridPan 30s linear infinite;
      pointer-events: none;
    }

    @keyframes gridPan {
      from { transform: translateY(0); }
      to   { transform: translateY(48px); }
    }

    .blob {
      position: fixed;
      border-radius: 50%;
      filter: blur(140px);
      opacity: 0.1;
      pointer-events: none;
    }
    .blob-1 { width: 600px; height: 600px; background: var(--accent); top: -200px; right: -200px; }
    .blob-2 { width: 400px; height: 400px; background: var(--accent2); bottom: -150px; left: -100px; }

    /* Layout */
    .page {
      position: relative;
      z-index: 10;
      max-width: 1000px;
      margin: 0 auto;
      padding: 3rem 2rem 5rem;
      animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes pageIn {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Header */
    header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
      gap: 1rem;
    }

    .logo {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      color: var(--accent);
      text-transform: uppercase;
      margin-bottom: 0.4rem;
      opacity: 0.8;
    }

    h1 {
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    h1 span {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--muted);
      font-family: 'Space Mono', monospace;
      font-size: 0.72rem;
      text-decoration: none;
      letter-spacing: 0.05em;
      border: 1px solid var(--border);
      padding: 0.5rem 1rem;
      border-radius: 2px;
      transition: color 0.2s, border-color 0.2s;
    }
    .back-btn:hover { color: var(--accent); border-color: var(--accent); }

    /* Stats bar */
    .stats-bar {
      display: flex;
      gap: 1px;
      margin-bottom: 1.5rem;
    }

    .stat {
      background: var(--surface);
      border: 1px solid var(--border);
      flex: 1;
      padding: 1rem 1.2rem;
      border-radius: 2px;
    }

    .stat-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: var(--muted);
      text-transform: uppercase;
      margin-bottom: 0.3rem;
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--accent), #7b61ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Table container */
    .table-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 2px;
      overflow: hidden;
      position: relative;
    }

    .table-wrap::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead tr {
      background: rgba(0,229,255,0.04);
      border-bottom: 1px solid var(--border);
    }

    th {
      font-family: 'Space Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 0.85rem 1.2rem;
      text-align: left;
      font-weight: 400;
    }

    tbody tr {
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
      animation: rowIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--row-hover); }

    tbody tr:nth-child(1)  { animation-delay: 0.00s; }
    tbody tr:nth-child(2)  { animation-delay: 0.05s; }
    tbody tr:nth-child(3)  { animation-delay: 0.10s; }
    tbody tr:nth-child(4)  { animation-delay: 0.15s; }
    tbody tr:nth-child(5)  { animation-delay: 0.20s; }
    tbody tr:nth-child(6)  { animation-delay: 0.25s; }
    tbody tr:nth-child(7)  { animation-delay: 0.30s; }
    tbody tr:nth-child(8)  { animation-delay: 0.35s; }
    tbody tr:nth-child(9)  { animation-delay: 0.40s; }
    tbody tr:nth-child(10) { animation-delay: 0.45s; }
    tbody tr:nth-child(n+11) { animation-delay: 0.50s; }

    @keyframes rowIn {
      from { opacity: 0; transform: translateX(-10px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    td {
      padding: 0.9rem 1.2rem;
      font-size: 0.85rem;
      vertical-align: middle;
    }

    /* Column: index */
    .col-index {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      color: var(--muted);
      width: 50px;
    }

    /* Column: short ID */
    .col-id .badge {
      display: inline-block;
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      color: var(--accent);
      background: rgba(0,229,255,0.08);
      border: 1px solid rgba(0,229,255,0.18);
      padding: 0.25em 0.7em;
      border-radius: 2px;
      letter-spacing: 0.05em;
    }

    /* Column: URL */
    .col-url a {
      color: var(--text);
      text-decoration: none;
      font-family: 'Space Mono', monospace;
      font-size: 0.72rem;
      color: var(--muted);
      display: block;
      max-width: 380px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      transition: color 0.2s;
    }
    .col-url a:hover { color: var(--accent); }

    /* Column: clicks */
    .col-clicks {
      width: 110px;
      text-align: right;
    }

    .click-count {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--text);
    }

    .click-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent2);
      flex-shrink: 0;
    }

    /* Empty state */
    .empty {
      text-align: center;
      padding: 5rem 2rem;
      color: var(--muted);
    }

    .empty-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      opacity: 0.4;
    }

    .empty p {
      font-family: 'Space Mono', monospace;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
    }

    .empty a {
      display: inline-block;
      margin-top: 1.2rem;
      color: var(--accent);
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      text-decoration: none;
      border: 1px solid rgba(0,229,255,0.3);
      padding: 0.5rem 1.2rem;
      border-radius: 2px;
      transition: background 0.2s;
    }
    .empty a:hover { background: rgba(0,229,255,0.08); }
  </style>
</head>
<body>
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>

  <div class="page">
    <header>
      <div>
        <div class="logo">shrtnr.io</div>
        <h1>All <span>URLs</span></h1>
      </div>
      <a href="/" class="back-btn">← New URL</a>
    </header>

    <% if (locals.result && result.length > 0) { %>

    <!-- Stats -->
    <div class="stats-bar">
      <div class="stat">
        <div class="stat-label">Total Links</div>
        <div class="stat-value"><%= result.length %></div>
      </div>
      <div class="stat">
        <div class="stat-label">Total Clicks</div>
        <div class="stat-value"><%= result.reduce((s, u) => s + u.visitHistory.length, 0) %></div>
      </div>
      <div class="stat">
        <div class="stat-label">Avg. Clicks</div>
        <div class="stat-value">
          <%= result.length ? (result.reduce((s, u) => s + u.visitHistory.length, 0) / result.length).toFixed(1) : 0 %>
        </div>
      </div>
    </div>

    <!-- Table -->
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Short ID</th>
            <th>Destination URL</th>
            <th style="text-align:right">Clicks</th>
          </tr>
        </thead>
        <tbody>
          <% result.forEach((url, index) => { %>
          <tr>
            <td class="col-index"><%= String(index + 1).padStart(2, '0') %></td>
            <td class="col-id"><span class="badge"><%= url.shortId %></span></td>
            <td class="col-url">
              <a href="<%= url.redirectUrl %>" target="_blank" title="<%= url.redirectUrl %>">
                <%= url.redirectUrl %>
              </a>
            </td>
            <td class="col-clicks">
              <span class="click-count">
                <span class="click-dot"></span>
                <%= url.visitHistory.length %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% } else { %>
    <div class="table-wrap">
      <div class="empty">
        <div class="empty-icon">⬡</div>
        <p>// no urls yet. the void awaits.</p>
        <a href="/">Create your first short URL</a>
      </div>
    </div>
    <% } %>
  </div>
</body>
</html>
